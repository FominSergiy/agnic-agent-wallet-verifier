# AI Gateway — one of these is required
OPENROUTER_API_KEY=sk-or-...       # default fallback gateway
AGNIC_API_KEY=                     # agnic platform key (not wired yet)

# Optional: override the default model used for synthesis
AI_MODEL=anthropic/claude-sonnet-4-6

# Optional: restrict CORS to your frontend origin
ALLOWED_ORIGIN=http://localhost:5173

# Optional: port (default 8000)
PORT=8000
